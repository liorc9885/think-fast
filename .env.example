# Server-only env vars (set these in the Vercel project settings).
# NEVER commit real values; NEVER expose the service-role key to clients.

# Supabase project URL, e.g. https://dhtjnpdwvuwgzdymfkra.supabase.co
SUPABASE_URL=

# Supabase SERVICE-ROLE key (full DB access). Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of extra allowed CORS origins (optional).
# The Capacitor origins (capacitor://localhost, https://localhost) and the
# deployment's own origin are always allowed. Add the production web origin
# here if the game is served from a different domain than the API.
CORS_ALLOWED_ORIGINS=
